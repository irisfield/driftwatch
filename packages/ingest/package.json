{
  "name": "@irisfield/driftwatch-ingest",
  "version": "0.0.1",
  "description": "CLI: scrape, chunk, embed, and upsert docs into pgvector.",
  "type": "module",
  "private": true,
  "bin": {
    "driftwatch-ingest": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache src",
    "format": "prettier --write \"src/**/*.ts\" --list-different"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "gpt-tokenizer": "^3.4.0",
    "node-html-parser": "^7.1.0",
    "pg": "^8.21.0"
  },
  "license": "MIT"
}
