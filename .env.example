# driftwatch — environment variables
# Copy to .env and fill in. Never commit .env.

# --- Supabase (live project: the deployed MCP server + ingestion target) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for the live project (Transaction pooler / Supavisor, port 6543)
DATABASE_URL=

# --- Embeddings (ingestion + query embedding) ---
# Default model: gemini-embedding-001 (truncated to 1536 dims via output_dimensionality).
# Get a free Gemini API key from Google AI Studio. Set GEMINI_API_KEY to use it.
# To use OpenAI instead, set EMBEDDING_MODEL to an OpenAI model (e.g. text-embedding-3-small)
# and set OPENAI_API_KEY. Provider is selected by the EMBEDDING_MODEL name prefix.
GEMINI_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001

# --- LLM-as-judge (diagnostic only, never the hard CI gate) ---
# Default model: gemini-2.5-flash-lite, so JUDGE_API_KEY can just be your GEMINI_API_KEY.
# gemini-2.5-flash-lite has its own free-tier request quota, separate from
# gemini-2.5-flash and the embedding models. To use OpenAI instead, set JUDGE_MODEL
# to an OpenAI model (e.g. gpt-4o-mini) and point JUDGE_API_KEY at an OpenAI key.
# Provider is selected by JUDGE_MODEL's name prefix.
JUDGE_API_KEY=
JUDGE_MODEL=gemini-2.5-flash-lite

# --- Golden dataset bootstrap (synthetic query generation) ---
# Default model: gemini-2.5-flash-lite, uses GEMINI_API_KEY above. It has its own
# free-tier request quota, separate from gemini-2.5-flash and the embedding models,
# which matters for bootstrapping dozens of queries in one run. To use OpenAI
# instead, set BOOTSTRAP_MODEL to an OpenAI model (e.g. gpt-4o-mini); provider is
# selected by BOOTSTRAP_MODEL's name prefix.
BOOTSTRAP_MODEL=gemini-2.5-flash-lite

# --- CI database (SEPARATE throwaway Postgres+pgvector; never the real project) ---
# In GitHub Actions this points at the raw pgvector/pgvector:pg16 service container.
# Locally it can point at a local docker pgvector.
CI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
